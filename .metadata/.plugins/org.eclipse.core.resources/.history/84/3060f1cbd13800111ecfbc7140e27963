package com.io.controllers;

import java.util.List;

import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.data.domain.Page;
import org.springframework.data.domain.Pageable;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.CrossOrigin;
import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PatchMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.RestController;

import com.io.entity.Product;
import com.io.entity.ProductDTO;
import com.io.service.ProductService;
import com.io.validations.APIResponse;
import com.io.validations.NoProductFoundException;

import jakarta.validation.Valid;

/**
 * This Main Controller class where are requests passes from this class and this
 * contains all the API methods
 * 
 * @author Shekar
 */

@RestController
@RequestMapping("/productcontroller")
@CrossOrigin(origins = "http://localhost:4200")
public class ProductController {

	private static final Logger log = LoggerFactory.getLogger(ProductController.class);

	@Autowired
	private ProductService productService;

	/**
	 * Method getAllProducts give you all the products available in
	 * 
	 * @param Not applicable
	 */
	@GetMapping("/")
	public ResponseEntity<Page> getAllProducts(Pageable pageable) {
		log.info("ProductController : getAllProducts execution starts FROM INFO");
		log.debug("ProductController : getAllProducts execution starts FROM DEBUG");

		ResponseEntity<Page> responseEntity;
		Page<Product> page = productService.getAllProdcts(pageable);
		if (page.isEmpty()) {

			responseEntity = new ResponseEntity("No records found ", HttpStatus.NOT_FOUND);
		} else {
			log.info("PAGE : " + page.getContent());

			responseEntity = new ResponseEntity(page, HttpStatus.OK);
		}
		return responseEntity;

	}

	/**
	 * Method createProduct method create a new product in Database
	 * 
	 * @param Product
	 */
	@PostMapping("/createProduct")
	public ResponseEntity<Product> createProduct(@Valid @RequestBody Product product) {
		log.info("ProductController : createProduct execution starts");

		Product savedproduct = productService.createProduct(product);

		log.info("ProductController : createProduct execution ends");
		return new ResponseEntity<Product>(savedproduct, HttpStatus.CREATED);
	}

	/**
	 * Method getByProductbyId is to fetch products by ID
	 * 
	 * @param Long id
	 */
	// Example : http://localhost:8080/api/product/1

	@GetMapping("/getProductbyId/{id}")
	public ResponseEntity<Product> getByProductbyId(@PathVariable("id") Long id) {
		log.info("ProductController : getByProductbyId execution starts");

		Product product = productService.findById(id)
				.orElseThrow(() -> new NoProductFoundException("Product not found with Id : " + id));
		log.info("ProductController : getByProductbyId execution ends");

		return ResponseEntity.ok(product);

	}

	/**
	 * Method deleteProduct is to delete a product which is soft delete
	 * 
	 * @param id
	 */
	@DeleteMapping("/{id}")
	public ResponseEntity<String> deleteProduct(@PathVariable Long id) {
		log.info("ProductController : deleteProduct execution starts");

		productService.deleteProduct(id);

		return new ResponseEntity<String>("Product deleted successfully !", HttpStatus.OK);
	}

	/**
	 * Method updateProduct is to update a product details
	 * 
	 * @param Product
	 */

	@PutMapping("/{id}")
	public ResponseEntity<Product> updateProduct(@PathVariable Long id, @Valid @RequestBody Product product) {
		log.info("ProductController : updateProduct execution starts");

		Product savedproduct = productService.updateProduct(product);
		log.info("ProductController : updateProduct execution ends");

		return new ResponseEntity<Product>(savedproduct, HttpStatus.CREATED);

	}

	/**
	 * Method partialUpdateProduct is to update a product details
	 * 
	 * @param Product
	 */

	@PatchMapping("/{id}")
	public ResponseEntity<ProductDTO> partialUpdateProduct(@PathVariable Long id,
			@Valid @RequestBody ProductDTO productDTO) {
		log.info("ProductController : partialUpdateProduct execution starts : " + id);

		ProductDTO savedProductDTO = productService.partialUpdateProduct(id, productDTO);
		log.info("ProductController : partialUpdateProduct execution ends");

		return ResponseEntity.ok(savedProductDTO);

	}

	/**
	 * Method getByCategory is to fetch products with category by paging
	 * 
	 * @param String, Pageable
	 */
	@GetMapping("/getByCategory")
	public Product getByCategory(@RequestParam @Valid String category) {
		return productService.getProductsByCategory(category);
	}

	@PostMapping("/getProductsByName")
	public ResponseEntity<List<ProductDTO>> getProductsByName(String name) {

		List<ProductDTO> listOfproductDTO = productService.getProductByName(name);

		log.info("ProductController : getProductByName execution ends");
		return ResponseEntity.ok(listOfproductDTO);
	}

	@PostMapping("/findProductWithsameName")
	public ResponseEntity findProductWithsameName(@RequestParam String name) {

		Page<Product> page = productService.findProductWithsameName(name, Pageable.unpaged());

		page.getContent().forEach(p -> System.out.print(p.getQuantity()));

		APIResponse<List<Product>> apiResponse = new APIResponse<List<Product>>();

		if (page.isEmpty()) {
			apiResponse.setMessage("No P F with Name : " + name);
		} else {
			apiResponse.setMessage("DATA Fetched with Name : " + name);

			apiResponse.setData(page.getContent());
		}
		return ResponseEntity.ok(apiResponse);

	}

	@PostMapping("/findByNameIgnoreCase")
	public List<ProductDTO> findByNameIgnoreCase(@RequestBody ProductDTO productDTO) {
		
		

		List<ProductDTO> list = productService.findByNameIgnoreCaseAndDeletedFalse(productDTO.getName());

		return list;

	}

}